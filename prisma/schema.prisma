generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Urls {
  id       String    @id @default(cuid())
  url      String    @unique
  count    Int       @default(0)
  destiny  String
  createAt DateTime  @default(now())
  expireAt DateTime?
  authorId String?
  number   Int       @default(autoincrement())
}
